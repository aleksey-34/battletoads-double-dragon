{
  "name": "battletoads-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "start": "ts-node src/server.ts",
    "build": "tsc",
    "dev": "ts-node --watch src/server.ts",
    "compare:tv": "ts-node src/backtest/compareTvTrades.ts",
    "test:integration": "cucumber-js --require-module ts-node/register --require tests/integration/steps/**/*.ts tests/integration/features/**/*.feature",
    "checkup": "npm run build && npm run test:integration"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bottleneck": "^2.19.5",
    "bybit-api": "^3.10.0",
    "ccxt": "^4.4.82",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/sqlite3": "^3.1.11",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
